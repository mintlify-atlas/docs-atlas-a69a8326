  "keyFeatures": [
    "Knowledge graph construction from documents using GraphRAG",
    "Multi-agent simulation with independent personalities and memory",
    "Parallel simulation across Twitter and Reddit platforms",
    "AI-powered report generation with interactive analysis",
    "Real-time agent interviews and conversations",
    "LLM-driven ontology and profile generation",
    "Docker deployment support"
  ],
  "publicApiSurface": [
    "POST /api/graph/ontology/generate - Upload documents and generate ontology",
    "POST /api/graph/build - Build knowledge graph from ontology",
    "POST /api/simulation/create - Create new simulation",
    "POST /api/simulation/prepare - Prepare simulation environment",
    "GET /api/simulation/entities/{graph_id} - Get graph entities",
    "POST /api/report/generate - Generate prediction report",
    "POST /api/report/chat - Chat with report agent",
    "GET /api/simulation/{simulation_id}/profiles - Get agent profiles"
  ]
